# ============================================================
# ADVENTURER - Environment variables template
# Copy to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ============================================================

# Public URL of the app (used for Stripe redirects, emails, etc.)
NEXT_PUBLIC_APP_URL=https://adventurer-outdoor.vercel.app

# ---- Supabase ----
# Get these from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://avldyvgvouzpeprygvyw.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# ⚠️ Service role key is SERVER-ONLY, never expose to client. Keep secret.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Stripe ----
# Get from https://dashboard.stripe.com/apikeys
# Start with TEST keys (sk_test_…, pk_test_…)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# After creating a webhook endpoint at https://dashboard.stripe.com/webhooks
# pointing to https://<your-url>/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# ---- Resend (transactional emails) ----
# Sign up at https://resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_FROM="Adventurer <hello@adventurer-outdoor.com>"

# ---- Stripe Connect fees (basis points, 1000 = 10%) ----
STRIPE_PLATFORM_FEE_BPS=1000

# ---- Admin ----
# Token for accessing /api/admin/stats — set to a strong random value
ADMIN_TOKEN=

# ---- Optional: Anthropic for Coach AI ----
ANTHROPIC_API_KEY=
